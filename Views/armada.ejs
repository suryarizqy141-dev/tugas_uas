<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Armada Kami - DT TRAVEL</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            --accent-color: #2563eb;
            --bg-color: #f8fafc;
            --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
            --premium-border: 1px solid rgba(226, 232, 240, 0.8);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            color: #0f172a;
        }

        .custom-navbar {
            background-color: #ffffff;
            border-bottom: var(--premium-border);
        }
        .nav-link {
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            color: #475569 !important;
            transition: color 0.2s ease;
        }
        .nav-link:hover {
            color: var(--accent-color) !important;
        }

        /* Armada Card */
        .armada-card {
            border: var(--premium-border);
            border-radius: 20px;
            overflow: hidden;
            background: #ffffff;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: var(--card-shadow);
        }
        .armada-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08);
        }

        .img-wrapper {
            height: 220px;
            overflow: hidden;
            background-color: #f1f5f9;
            position: relative;
        }
        .img-wrapper img {
            object-fit: cover;
            width: 100%;
            height: 100%;
            transition: transform 0.5s ease;
        }
        .armada-card:hover .img-wrapper img {
            transform: scale(1.05);
        }

        .capacity-badge {
            position: absolute;
            bottom: 15px;
            right: 15px;
            background-color: rgba(15, 23, 42, 0.85);
            color: #ffffff;
            font-size: 0.8rem;
            font-weight: 700;
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            backdrop-filter: blur(4px);
        }

        .facility-item {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background-color: #f1f5f9;
            color: #475569;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.3rem 0.6rem;
            border-radius: 6px;
            margin-right: 4px;
            margin-bottom: 6px;
        }

        footer {
            background-color: #0f172a;
            color: #94a3b8;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light custom-navbar sticky-top py-3 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-extrabold text-dark tracking-wider" href="/" style="font-size: 1.4rem;">DT TRAVEL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#dtNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="dtNav">
                <ul class="navbar-nav ms-auto fw-bold text-uppercase gap-2 align-items-center">
                    <li class="nav-item"><a class="nav-link px-3" href="/">Beranda</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="/layanan">Layanan</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="/rute">Rute</a></li>
                    <li class="nav-item"><a class="nav-link px-3 active text-primary" href="/armada">Armada</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm px-4 text-white shadow-sm ms-2 rounded-3 py-2" href="/pemesanan">Pesan Sekarang</a></li>
                    <li class="nav-item"><a class="btn btn-outline-secondary btn-sm px-3 ms-1 rounded-3 py-2" href="/login">Admin Portal</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <main class="container my-5 py-4">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold text-uppercase tracking-widest small">Our Fleet</span>
            <h2 class="fw-extrabold text-dark mt-1">ARMADA EKSEKUTIF KAMI</h2>
            <p class="text-muted small">Kendaraan prima berstandar tinggi yang selalu dirawat secara berkala.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <% if (dataArmada.length === 0) { %>
                <div class="col-12 text-center text-muted py-5">
                    <div class="fs-2 mb-2"><i class="bi bi-truck text-muted"></i></div>
                    <p class="small fw-semibold">Data spesifikasi armada belum tersedia.</p>
                </div>
            <% } else { %>
                <% dataArmada.forEach(a => { %>
                    <div class="col-md-4">
                        <div class="card h-100 armada-card">
                            <div class="img-wrapper">
                                <img src="<%= a.foto_url || 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRjdc9YkDm0O8xe-RaqnIErSmJDLxdiqgWGhP35lBo9cz7kC6aCqLexGJo&s' %>" alt="<%= a.nama_kendaraan %>">
                                <div class="capacity-badge"><i class="bi bi-people-fill me-1"></i> <%= a.kapasitas %> Penumpang</div>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-extrabold text-dark mb-3"><%= a.nama_kendaraan %></h5>
                                
                                <p class="text-muted small mb-4 lh-lg">Armada premium yang dipelihara secara rutin demi menjamin keamanan dan kenyamanan maksimal Anda sepanjang perjalanan.</p>
                                
                                <div>
                                    <div class="facility-item"><i class="bi bi-wind"></i> Full AC</div>
                                    <div class="facility-item"><i class="bi bi-lightning-charge-fill"></i> USB Charger</div>
                                    <div class="facility-item"><i class="bi bi-music-note-beamed"></i> Music & TV</div>
                                    <div class="facility-item"><i class="bi bi-bookmark-star-fill"></i> Captain Seat</div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="text-white pt-5 pb-4 mt-5">
        <div class="container text-center">
            <p class="small text-white-50 mb-0">&copy; 2026 DT TRAVEL. Premium Service All Rights Reserved.</p>
        </div>
    </footer>

</body>
</html>