<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservasi Tiket Online - DT TRAVEL</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            --accent-color: #2563eb;
            --accent-hover: #1d4ed8;
            --bg-color: #f8fafc;
            --card-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            --premium-border: 1px solid rgba(226, 232, 240, 0.8);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            color: #0f172a;
        }

        /* Navbar Styling */
        .custom-navbar {
            background-color: #ffffff;
            border-bottom: var(--premium-border);
        }
        .nav-link {
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            color: #475569 !important;
            transition: color 0.2s ease;
        }
        .nav-link:hover {
            color: var(--accent-color) !important;
        }

        /* Form Styling */
        .form-container {
            background: #ffffff;
            border-radius: 24px;
            border: var(--premium-border);
            box-shadow: var(--card-shadow);
        }

        .section-header {
            background: var(--primary-gradient);
            color: #ffffff;
            padding: 3rem 2rem;
            border-radius: 24px;
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .form-label-custom {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #475569;
            margin-bottom: 0.5rem;
        }

        .form-control-custom, .form-select-custom {
            padding: 0.8rem 1.2rem;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 500;
            color: #0f172a;
            transition: all 0.2s ease;
            background-color: #f8fafc;
        }

        .form-control-custom:focus, .form-select-custom:focus {
            outline: none;
            border-color: var(--accent-color);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
        }

        .btn-submit {
            background: var(--primary-gradient);
            color: #ffffff;
            border: none;
            padding: 1rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.1), 0 2px 4px -2px rgba(15, 23, 42, 0.1);
        }

        .btn-submit:hover {
            opacity: 0.95;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.15), 0 4px 6px -4px rgba(15, 23, 42, 0.15);
        }

        footer {
            background-color: #0f172a;
            color: #94a3b8;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light custom-navbar sticky-top py-3 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-extrabold text-dark tracking-wider" href="/" style="font-size: 1.4rem;">DT TRAVEL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#dtNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="dtNav">
                <ul class="navbar-nav ms-auto fw-bold text-uppercase gap-2 align-items-center">
                    <li class="nav-item"><a class="nav-link px-3" href="/">Beranda</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="/layanan">Layanan</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="/rute">Rute</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="/armada">Armada</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm px-4 text-white shadow-sm ms-2 rounded-3 py-2" href="/pemesanan">Pesan Sekarang</a></li>
                    <li class="nav-item"><a class="btn btn-outline-secondary btn-sm px-3 ms-1 rounded-3 py-2" href="/login">Admin Portal</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <main class="container my-5 py-2" style="max-width: 800px;">
        
        <!-- HEADER -->
        <div class="section-header shadow-sm">
            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold mb-2">SISTEM RESERVASI ONLINE</span>
            <h2 class="fw-extrabold tracking-tight mb-2">Booking Perjalanan Anda</h2>
            <p class="mb-0 text-white-50 small">Lengkapi formulir di bawah ini dengan data yang valid untuk reservasi cepat.</p>
        </div>

        <!-- NOTIFICATION -->
        <% if (message) { %>
            <div class="alert alert-<%= message.type === 'success' ? 'success' : 'danger' %> alert-dismissible fade show rounded-4 p-4 shadow-sm border-0 mb-4" role="alert">
                <div class="d-flex align-items-center gap-3">
                    <div class="fs-4"><i class="bi <%= message.type === 'success' ? 'bi-check-circle-fill text-success' : 'bi-exclamation-triangle-fill text-danger' %>"></i></div>
                    <div>
                        <p class="mb-0 small fw-bold"><%= message.text %></p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <!-- FORM CARD -->
        <div class="form-container p-4 p-md-5">
            <form action="/pesan" method="POST">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Nama Lengkap</label>
                        <input type="text" name="nama" class="form-control form-control-custom w-100" placeholder="Contoh: Budi Santoso" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">No. WhatsApp Aktif</label>
                        <input type="tel" name="whatsapp" class="form-control form-control-custom w-100" placeholder="Contoh: 08123456789" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Pilih Rute Destinasi</label>
                        <select name="rute" class="form-select form-select-custom w-100" required>
                            <option value="" disabled selected>-- Pilih Rute --</option>
                            <% dataRute.forEach(r => { %>
                                <option value="<%= r.asal %> - <%= r.tujuan %>"><%= r.asal %> ke <%= r.tujuan %> (Rp <%= Number(r.harga).toLocaleString('id-ID') %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Pilihan Tipe Armada</label>
                        <select name="armada" class="form-select form-select-custom w-100" required>
                            <option value="" disabled selected>-- Pilih Jenis Mobil --</option>
                            <% dataArmada.forEach(a => { %>
                                <option value="<%= a.nama_kendaraan %>"><%= a.nama_kendaraan %> (Kapasitas: <%= a.kapasitas %> Kursi)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Tanggal Keberangkatan</label>
                        <input type="date" name="tanggal" class="form-control form-control-custom w-100" required id="tanggalInput">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Jumlah Penumpang</label>
                        <input type="number" name="penumpang" min="1" max="10" class="form-control form-control-custom w-100" placeholder="Jumlah Kursi" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label-custom">Catatan Tambahan (Opsional)</label>
                        <textarea name="catatan" rows="3" class="form-control form-control-custom w-100" style="padding-left: 1.2rem;" placeholder="Contoh: Bawa koper besar / jemput di lobby hotel..."></textarea>
                    </div>
                    <div class="col-12 mt-4 pt-2">
                        <button type="submit" class="btn-submit w-100 fw-bold"><i class="bi bi-send-fill me-2"></i> KIRIM FORM RESERVASI SEKARANG</button>
                    </div>
                </div>
            </form>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="text-white pt-5 pb-4 mt-5">
        <div class="container text-center">
            <p class="small text-white-50 mb-0">&copy; 2026 DT TRAVEL. Premium Service All Rights Reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set minimal date to today
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('tanggalInput').min = today;
    </script>
</body>
</html>