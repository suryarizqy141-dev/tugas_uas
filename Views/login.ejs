<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Administrator - DT TRAVEL</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            --accent-color: #2563eb;
            --accent-hover: #1d4ed8;
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-color);
            background-image: radial-gradient(at 0% 0%, rgba(37, 99, 235, 0.05) 0px, transparent 50%),
                              radial-gradient(at 50% 0%, rgba(147, 51, 234, 0.05) 0px, transparent 50%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 1.5rem;
        }

        .login-card {
            background: var(--card-bg);
            border-radius: 24px;
            border: 1px solid rgba(226, 232, 240, 0.8);
            width: 100%;
            max-width: 440px;
            box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.08);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .login-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 30px 60px -15px rgba(15, 23, 42, 0.12);
        }

        .card-header-accent {
            background: var(--primary-gradient);
            padding: 2.5rem 2rem;
            text-align: center;
            color: #ffffff;
        }

        .card-body-content {
            padding: 2.5rem 2.5rem 2rem 2.5rem;
        }

        .form-label-custom {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #475569;
            margin-bottom: 0.5rem;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .input-group-custom i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
            transition: color 0.2s ease;
        }

        .form-control-custom {
            width: 100%;
            padding: 0.8rem 1rem 0.8rem 2.8rem;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-main);
            transition: all 0.2s ease;
            background-color: #f8fafc;
        }

        .form-control-custom::placeholder {
            color: #94a3b8;
        }

        .form-control-custom:focus {
            outline: none;
            border-color: var(--accent-color);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
        }

        .form-control-custom:focus + i {
            color: var(--accent-color);
        }

        .btn-submit {
            background: var(--primary-gradient);
            color: #ffffff;
            border: none;
            width: 100%;
            padding: 0.9rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.1), 0 2px 4px -2px rgba(15, 23, 42, 0.1);
        }

        .btn-submit:hover {
            opacity: 0.95;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.15), 0 4px 6px -4px rgba(15, 23, 42, 0.15);
        }

        .btn-submit:active {
            transform: translateY(1px);
        }

        .alert-custom {
            background-color: #fef2f2;
            color: #dc2626;
            border: 1px solid #fee2e2;
            border-radius: 12px;
            padding: 0.8rem;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1.5rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-muted);
            transition: color 0.2s ease;
        }

        .back-link:hover {
            color: var(--accent-color);
        }
    </style>
</head>
<body>

    <div class="login-card shadow-lg">
        <!-- HEADER ACCENT -->
        <div class="card-header-accent">
            <div class="fs-2 mb-2"><i class="bi bi-shield-lock-fill"></i></div>
            <h4 class="fw-extrabold tracking-wide mb-1">DT TRAVEL</h4>
            <p class="small text-white-50 mb-0">Portal Otentikasi Administrator Resmi</p>
        </div>

        <!-- FORM CONTENT -->
        <div class="card-body-content">
            <% if (error) { %>
                <div class="alert-custom" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span><%= error %></span>
                </div>
            <% } %>

            <form action="/login" method="POST">
                <!-- Username Input -->
                <div class="mb-3">
                    <label class="form-label-custom d-block">Username</label>
                    <div class="input-group-custom">
                        <input type="text" name="username" class="form-control-custom" placeholder="Masukkan nama akun..." required autocomplete="username">
                        <i class="bi bi-person-fill"></i>
                    </div>
                </div>

                <!-- Password Input -->
                <div class="mb-4">
                    <label class="form-label-custom d-block">Password</label>
                    <div class="input-group-custom">
                        <input type="password" name="password" class="form-control-custom" placeholder="••••••••" required autocomplete="current-password">
                        <i class="bi bi-key-fill"></i>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-submit mb-4">MASUK KE DASHBOARD</button>

                <!-- Navigation link -->
                <div class="text-center">
                    <a href="/" class="back-link">
                        <i class="bi bi-arrow-left"></i> Kembali ke Beranda
                    </a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>