<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - DT TRAVEL</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            --accent-color: #2563eb;
            --bg-light: #f8fafc;
            --text-dark: #0f172a;
            --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
            --premium-border: 1px solid rgba(226, 232, 240, 0.8);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            min-height: 100vh;
        }

        /* Navbar & Header */
        .custom-navbar {
            background-color: #ffffff;
            border-bottom: var(--premium-border);
        }

        .dashboard-header {
            background: var(--primary-gradient);
            color: #ffffff;
            border-radius: 20px;
            padding: 2.5rem;
            margin-bottom: 2.5rem;
            box-shadow: 0 20px 25px -5px rgba(30, 41, 59, 0.1), 0 8px 10px -6px rgba(30, 41, 59, 0.1);
        }

        /* Metric Cards */
        .stat-card {
            background: #ffffff;
            border: var(--premium-border);
            border-radius: 16px;
            box-shadow: var(--card-shadow);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08);
        }

        .icon-box {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .icon-blue { background-color: #eff6ff; color: #2563eb; }
        .icon-green { background-color: #f0fdf4; color: #16a34a; }
        .icon-purple { background-color: #faf5ff; color: #9333ea; }
        .icon-orange { background-color: #fff7ed; color: #ea580c; }

        /* Booking Table Section */
        .table-card {
            background: #ffffff;
            border: var(--premium-border);
            border-radius: 20px;
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        .table-responsive {
            margin: 0;
        }

        .custom-table th {
            background-color: #f1f5f9;
            color: #475569;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem 1.5rem;
            border-bottom: var(--premium-border);
        }

        .custom-table td {
            padding: 1.2rem 1.5rem;
            vertical-align: middle;
            border-bottom: var(--premium-border);
            font-size: 0.9rem;
        }

        .custom-table tr:last-child td {
            border-bottom: none;
        }

        .search-input {
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 0.6rem 1rem;
            font-size: 0.9rem;
            transition: all 0.2s ease;
            width: 280px;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }

        .badge-route {
            background-color: #f1f5f9;
            color: #334155;
            font-weight: 600;
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            font-size: 0.85rem;
        }

        .badge-armada {
            background-color: #eff6ff;
            color: #1e40af;
            font-weight: 600;
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            font-size: 0.85rem;
        }

        /* Action Buttons */
        .btn-delete {
            background-color: #fef2f2;
            color: #dc2626;
            border: 1px solid #fee2e2;
            border-radius: 8px;
            padding: 0.4rem 0.8rem;
            transition: all 0.2s;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .btn-delete:hover {
            background-color: #dc2626;
            color: #ffffff;
            border-color: #dc2626;
        }

        /* Footer */
        footer {
            background-color: #0f172a;
            color: #94a3b8;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light custom-navbar sticky-top py-3 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-extrabold text-dark tracking-wider" href="/" style="font-size: 1.4rem;">DT TRAVEL <span class="badge bg-dark fs-6 ms-1 px-2.5 py-1">ADMIN</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#dtNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="dtNav">
                <div class="navbar-nav ms-auto align-items-center gap-3">
                    <span class="text-secondary small fw-medium">Halo, <strong><%= adminNama %></strong></span>
                    <a href="/" class="btn btn-outline-secondary btn-sm px-3 rounded-3 py-2"><i class="bi bi-box-arrow-up-right me-1"></i> Buka Website</a>
                    <a href="/logout" class="btn btn-danger btn-sm px-3 rounded-3 py-2 fw-bold"><i class="bi bi-power me-1"></i> Keluar</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <main class="container my-5">
        
        <!-- HEADER -->
        <div class="dashboard-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold mb-2">SISTEM RESERVASI</span>
                <h1 class="fw-extrabold tracking-tight mb-1" style="font-size: 2.2rem;">Dashboard Panel Utama</h1>
                <p class="mb-0 opacity-80 small">Kelola seluruh pemesanan tiket, pantau okupansi, dan koordinasi dengan armada DT TRAVEL secara real-time.</p>
            </div>
            <div>
                <div class="bg-white bg-opacity-10 p-3 rounded-4 border border-white border-opacity-10">
                    <span class="small d-block text-white text-opacity-70 mb-1"><i class="bi bi-clock me-1"></i> Waktu Server</span>
                    <span class="fw-bold fs-5" id="serverTime">-- : --</span>
                </div>
            </div>
        </div>

        <!-- STATS -->
        <div class="row g-4 mb-5">
            <div class="col-6 col-md-3">
                <div class="stat-card p-4 h-100 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold">TOTAL RESERVASI</span>
                        <div class="icon-box icon-blue"><i class="bi bi-receipt"></i></div>
                    </div>
                    <div>
                        <h2 class="fw-extrabold mb-1"><%= stats.totalBookings %></h2>
                        <span class="text-secondary small">Pesanan Masuk</span>
                    </div>
                </div>
            </div>
            
            <div class="col-6 col-md-3">
                <div class="stat-card p-4 h-100 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold">TOTAL PENUMPANG</span>
                        <div class="icon-box icon-green"><i class="bi bi-people"></i></div>
                    </div>
                    <div>
                        <h2 class="fw-extrabold mb-1"><%= stats.totalPassengers %></h2>
                        <span class="text-secondary small">Kursi Terisi</span>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="stat-card p-4 h-100 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold">RUTE AKTIF</span>
                        <div class="icon-box icon-purple"><i class="bi bi-compass"></i></div>
                    </div>
                    <div>
                        <h2 class="fw-extrabold mb-1"><%= stats.activeRoutes %></h2>
                        <span class="text-secondary small">Destinasi</span>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="stat-card p-4 h-100 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted small fw-bold">JUMLAH FLEET</span>
                        <div class="icon-box icon-orange"><i class="bi bi-truck-flatbed"></i></div>
                    </div>
                    <div>
                        <h2 class="fw-extrabold mb-1"><%= stats.totalArmada %></h2>
                        <span class="text-secondary small">Unit Mobil Aktif</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- TABLE SECTION -->
        <div class="table-card">
            <!-- Table Controls -->
            <div class="p-4 border-bottom d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Daftar Transaksi Pemesanan</h5>
                    <p class="text-muted small mb-0">Total <%= bookings.length %> data terdaftar</p>
                </div>
                <div class="d-flex gap-2">
                    <div class="position-relative">
                        <input type="text" id="searchInput" class="search-input" placeholder="Cari Nama / WhatsApp..." onkeyup="filterTable()">
                    </div>
                </div>
            </div>

            <!-- Table Responsive -->
            <div class="table-responsive">
                <table class="table custom-table table-hover mb-0" id="bookingsTable">
                    <thead>
                        <tr>
                            <th>Waktu Booking</th>
                            <th>Nama Pelanggan</th>
                            <th>No. WhatsApp</th>
                            <th>Rute Perjalanan</th>
                            <th>Armada</th>
                            <th class="text-center">Penumpang</th>
                            <th>Tanggal Keberangkatan</th>
                            <th>Catatan</th>
                            <th class="text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (bookings.length === 0) { %>
                            <tr>
                                <td colspan="9" class="text-center text-muted py-5">
                                    <div class="fs-4 mb-2">📭</div>
                                    <span class="small fw-medium">Belum ada transaksi pemesanan tiket masuk saat ini.</span>
                                </td>
                            </tr>
                        <% } else { %>
                            <% bookings.forEach(b => { %>
                                <tr>
                                    <td class="text-muted small">
                                        <%= new Date(b.created_at).toLocaleString('id-ID', {day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit'}) %>
                                    </td>
                                    <td>
                                        <strong><%= b.nama_lengkap %></strong>
                                    </td>
                                    <td>
                                        <a href="https://wa.me/<%= b.no_whatsapp.replace(/^0/, '62') %>" target="_blank" class="text-success text-decoration-none fw-semibold">
                                            <i class="bi bi-whatsapp me-1"></i> <%= b.no_whatsapp %>
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge-route"><%= b.rute %></span>
                                    </td>
                                    <td>
                                        <span class="badge-armada"><%= b.armada %></span>
                                    </td>
                                    <td class="text-center fw-bold text-dark">
                                        <%= b.jumlah_penumpang %> Orang
                                    </td>
                                    <td>
                                        <span class="fw-semibold text-secondary">
                                            <%= new Date(b.tanggal_keberangkatan).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted small"><%= b.catatan || '-' %></span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-delete" onclick="confirmDelete(<%= b.id %>, '<%= b.nama_lengkap %>')">
                                            <i class="bi bi-trash3-fill"></i> Hapus
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- DELETE CONFIRM MODAL -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-body p-4 text-center">
                    <div class="text-danger fs-1 mb-3">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Hapus Reservasi?</h5>
                    <p class="text-muted small mb-4">Apakah Anda yakin ingin menghapus reservasi atas nama <strong id="deleteTargetName">...</strong>? Tindakan ini tidak dapat dibatalkan.</p>
                    
                    <form id="deleteForm" method="POST">
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="button" class="btn btn-light px-4 py-2 rounded-3 fw-bold small" data-bs-dismiss="modal">Batal</button>
                            <button type="submit" class="btn btn-danger px-4 py-2 rounded-3 fw-bold small">Ya, Hapus Data</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="text-center py-4 mt-5">
        <div class="container">
            <p class="small mb-0 text-white-50">&copy; 2026 DT TRAVEL Admin Panel. Premium Services Portal.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Update Server Time
        function updateTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + ' WIB';
            document.getElementById('serverTime').innerText = timeString;
        }
        setInterval(updateTime, 1000);
        updateTime();

        // Search Filter
        function filterTable() {
            const input = document.getElementById('searchInput');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('bookingsTable');
            const tr = table.getElementsByTagName('tr');

            for (let i = 1; i < tr.length; i++) {
                let showRow = false;
                const tdName = tr[i].getElementsByTagName('td')[1];
                const tdPhone = tr[i].getElementsByTagName('td')[2];
                const tdRoute = tr[i].getElementsByTagName('td')[3];
                
                if (tdName || tdPhone || tdRoute) {
                    const txtName = tdName ? tdName.textContent || tdName.innerText : "";
                    const txtPhone = tdPhone ? tdPhone.textContent || tdPhone.innerText : "";
                    const txtRoute = tdRoute ? tdRoute.textContent || tdRoute.innerText : "";
                    
                    if (txtName.toLowerCase().indexOf(filter) > -1 || 
                        txtPhone.toLowerCase().indexOf(filter) > -1 ||
                        txtRoute.toLowerCase().indexOf(filter) > -1) {
                        showRow = true;
                    }
                }
                
                if (showRow) {
                    tr[i].style.display = "";
                } else {
                    // Check if it's the empty state row
                    if (tr[i].getElementsByTagName('td').length > 1) {
                        tr[i].style.display = "none";
                    }
                }
            }
        }

        // Delete Modal Handler
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
        function confirmDelete(id, name) {
            document.getElementById('deleteTargetName').innerText = name;
            document.getElementById('deleteForm').action = '/admin/bookings/delete/' + id;
            deleteModal.show();
        }
    </script>
</body>
</html>
